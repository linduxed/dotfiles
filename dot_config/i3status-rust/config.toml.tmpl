[theme]
theme = "space-villain"
[icons]
icons = "awesome4"

[[block]]
block = "disk_space"
path = "/"
info_type = "used"
format = " $icon $used/$total ($available.eng(w:2) free)"
alert_unit = "GB"
alert = 750
warning = 900

[[block]]
block = "memory"
format = " $icon $mem_used/$mem_total($mem_used_percents.eng(w:2))"

[[block]]
block = "keyboard_layout"
driver = "kbddbus"
format = "KB: $layout"

[[block]]
block = "load"
interval = 1
format = " $icon $1m.eng(w:4)"

[[block]]
block = "cpu"
interval = 1
format = " $icon $utilization"

[[block]]
block = "temperature"
format = " $icon max: $max $icon avg: $average"

{{- if .i3status_show_nvidia }}
[[block]]
block = "nvidia_gpu"
format = " $icon $utilization $memory $temperature"
interval = 1
{{- end }}

# [[block]]
# block = "pacman"
# interval = 43200
