[theme]
theme = "dracula"

[theme.overrides]
info_bg = { link = "idle_bg" }
info_fg = { link = "idle_fg" }
good_bg = { link = "idle_bg" }
good_fg = { link = "idle_fg" }

[icons]
icons = "awesome4"

[[block]]
block = "custom"
interval = 1
json = true
command = '''
fish -c "
switch (voxtype status 2>/dev/null; or echo offline)
    case recording
        echo \"{\\\"icon\\\":\\\"microphone\\\",\\\"text\\\":\\\"VT: REC\\\",\\\"state\\\":\\\"Critical\\\"}\"
    case transcribing
        echo \"{\\\"icon\\\":\\\"microphone_muted\\\",\\\"text\\\":\\\"VT: TX\\\",\\\"state\\\":\\\"Warning\\\"}\"
    case idle
        echo \"{\\\"icon\\\":\\\"microphone_muted\\\",\\\"text\\\":\\\"VT\\\",\\\"state\\\":\\\"Idle\\\"}\"
    case '*'
        echo \"{\\\"icon\\\":\\\"microphone\\\",\\\"text\\\":\\\"?\\\",\\\"state\\\":\\\"Info\\\"}\"
end
"
'''

[[block]]
block = "disk_space"
path = "/"
info_type = "used"
format = " $icon $used/$total ($available.eng(w:2) free)"
alert_unit = "GB"
alert = 750
warning = 900

[[block]]
block = "memory"
format = " $icon $mem_used/$mem_total($mem_used_percents.eng(w:2))"

[[block]]
block = "keyboard_layout"
driver = "kbddbus"
format = "KB: $layout"

[[block]]
block = "load"
interval = 1
format = " $icon $1m.eng(w:4)"

[[block]]
block = "cpu"
interval = 1
format = " $icon $utilization"

[[block]]
block = "temperature"
format = " $icon max: $max $icon avg: $average"

{{- if .i3status_show_nvidia }}
[[block]]
block = "nvidia_gpu"
format = " $icon $utilization $memory $temperature"
interval = 1
{{- end }}

