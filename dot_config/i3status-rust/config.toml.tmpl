[[block]]
block = "net"
device = "{{ .i3status_net_device }}"
format = " $icon $speed_down"
interval = 5

{{- if .i3status_show_battery }}
[[block]]
block = "battery"
format = " $icon $percentage"
{{- end }}

[[block]]
block = "sound"
driver = "pulseaudio"

[[block]]
block = "time"
interval = 1
format = "$icon $timestamp.datetime(f:'%a %-d %b %X W%V')"
