#!/usr/bin/bash
{{- if eq .chezmoi.hostname "primo" }}
s1=$(uname -r | sed 's/-lts$//')
s2=$(pacman -Q linux-lts | sed 's/linux-lts //' | sed 's/\.lts/-lts/')

echo "uname -r:  $(uname -r)"
echo "pacman -Q: $(pacman -Q linux-lts)"
echo ""
{{- else if eq .chezmoi.hostname "blackberry" }}
s1=$(pacman -Q linux-raspberrypi | sed 's/linux-raspberrypi //' | sed 's/\.arch/-arch/')
s2=$(uname -r | sed 's/-ARCH//')
{{- else }}
s1=$(pacman -Q linux | sed 's/linux //' | sed 's/\.arch/-arch/')
s2=$(uname -r | sed 's/-ARCH//')
{{- end }}

if [ "$s1" == "$s2" ]; then
  echo NO NEED
else
  echo REBOOT NECESSARY
fi
